# ----------------------------------------------------------------------------
# Copy to .env and adjust. Values below match docker-compose.yml defaults.
# ----------------------------------------------------------------------------

NODE_ENV=development

# Postgres
DATABASE_URL="postgresql://pm:pm@localhost:5432/pm?schema=public"

# Redis (BullMQ + presence/pubsub)
REDIS_URL="redis://localhost:6379"

# Auth — generate strong values for any non-local environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"            # seconds (15m)
JWT_REFRESH_TTL="1209600"       # seconds (14d)

# API
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_BUSINESS="price_xxx"

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="pm-attachments"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"

# Observability — when set, API errors (5xx) are reported to Sentry.
SENTRY_DSN=""

# Email — leave SMTP_URL empty to use a console transport (logs instead of
# sends) for local dev. Set to an SMTP connection string to deliver for real.
SMTP_URL=""
MAIL_FROM="PM SaaS <no-reply@pm.local>"

# Optional hardening: point the app at the non-superuser role created by the
# `app_role` migration so Postgres RLS policies apply to it (migrations still
# run as the owner above). See packages/db/prisma/migrations/*_app_role.
# DATABASE_URL="postgresql://pm_app:pm_app@localhost:5433/pm?schema=public"

# Web (Next.js) — exposed to browser
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
